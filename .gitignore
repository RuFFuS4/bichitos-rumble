node_modules
dist
.vite
*.local

.vercel

# Playwright output (npm run test:smoke) — test results + traces/videos
# regenerate on every run and can be large.
test-results
playwright-report
blob-report
playwright/.cache

# Per-user Claude Code / MCP config — paths inside .mcp.json are
# Windows-absolute (uvx.exe location) so the file doesn't transfer
# across machines as-is. Each developer keeps their own.
.claude/settings.local.json
.mcp.json

# Copied from game's public/models/critters/ by mesh2motion's prebuild
# hook. Not a source of truth — regenerated on every build/dev run.
mesh2motion/static/models/critters/

# Raw (pre-optimization) arena prop GLBs straight from the IA generator.
# These are hundreds of MB each (1M+ vertices before simplification);
# only the post-optimize output in public/models/arenas/<pack>/ ships.
# Keep the raw source locally for re-runs without re-downloading from
# the IA tool, but never commit.
public/models/arenas/_raw/

# Raw belt assets pre-optimization — optimizer writes clean copies to
# public/models/belts/ and public/images/belts/. The _raw/ counterparts
# are only for local re-runs.
public/models/_raw/
public/images/_raw/

# Ad-hoc scratch folder for asset optimization backups, one-off dumps,
# and other local-only workspace detritus. Tools like
# scripts/optimize-textures.mjs write pre-change copies here before
# mutating public/ assets.
.tmp/

# OS / editor junk
Thumbs.db
.DS_Store
*.swp
*.swo
.idea/
.vscode/*.log
